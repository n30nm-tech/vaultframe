generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Library {
  id            String      @id @default(cuid())
  name          String
  path          String      @unique
  enabled       Boolean     @default(true)
  scanStatus    String      @default("IDLE")
  scanQueuedAt  DateTime?
  scanStartedAt DateTime?
  scanFinishedAt DateTime?
  scanCurrentPath String?
  scanPendingFiles String[] @default([])
  scanResumed   Boolean     @default(false)
  scanTotalFiles Int        @default(0)
  scanFilesScanned Int      @default(0)
  scanVideosFound Int       @default(0)
  scanError     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastScannedAt DateTime?
  mediaItems    MediaItem[]
}

model MediaItem {
  id              String   @id @default(cuid())
  libraryId       String
  fullPath        String   @unique
  folderPath      String
  fileName        String
  title           String?
  thumbnailPath   String?
  storyboardPaths String[] @default([])
  storyboardTimestamps Float[] @default([])
  extension       String
  sizeBytes       BigInt?
  durationSeconds Int?
  missing         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSeenAt      DateTime
  library         Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  tags            Tag[]

  @@index([libraryId])
  @@index([libraryId, missing])
  @@index([updatedAt])
  @@index([createdAt])
  @@index([folderPath])
  @@index([sizeBytes])
  @@index([libraryId, updatedAt])
}

model Tag {
  id         String     @id @default(cuid())
  name       String     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  mediaItems MediaItem[]
}

model TagRule {
  id         String   @id @default(cuid())
  name       String
  target     String
  matchMode  String   @default("CONTAINS")
  pattern    String
  tagName    String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
}
