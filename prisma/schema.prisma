generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Library {
  id            String      @id @default(cuid())
  name          String
  path          String      @unique
  enabled       Boolean     @default(true)
  scanStatus    String      @default("IDLE")
  scanQueuedAt  DateTime?
  scanStartedAt DateTime?
  scanFinishedAt DateTime?
  scanCurrentPath String?
  scanPendingFiles String[] @default([])
  scanResumed   Boolean     @default(false)
  scanTotalFiles Int        @default(0)
  scanFilesScanned Int      @default(0)
  scanVideosFound Int       @default(0)
  scanError     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastScannedAt DateTime?
  mediaItems    MediaItem[]
}

model MediaItem {
  id              String   @id @default(cuid())
  libraryId       String
  fullPath        String   @unique
  folderPath      String
  fileName        String
  title           String?
  thumbnailPath   String?
  posterSelectionMode String @default("AUTO")
  posterReviewedAt DateTime?
  storyboardPaths String[] @default([])
  storyboardTimestamps Float[] @default([])
  extension       String
  sizeBytes       BigInt?
  durationSeconds Int?
  missing         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSeenAt      DateTime
  library         Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  tags            Tag[]

  @@index([libraryId])
  @@index([libraryId, missing])
  @@index([updatedAt])
  @@index([createdAt])
  @@index([folderPath])
  @@index([sizeBytes])
  @@index([libraryId, updatedAt])
}

model Tag {
  id         String     @id @default(cuid())
  name       String     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  mediaItems MediaItem[]
}

model TagRule {
  id         String   @id @default(cuid())
  name       String
  target     String
  matchMode  String   @default("CONTAINS")
  pattern    String
  tagName    String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
}

model Model {
  id             String       @id @default(cuid())
  name           String
  path           String       @unique
  enabled        Boolean      @default(true)
  coverAssetId   String?
  importStatus   String       @default("IDLE")
  importQueuedAt DateTime?
  importStartedAt DateTime?
  importFinishedAt DateTime?
  importCurrentPath String?
  importTotalFiles Int        @default(0)
  importFilesScanned Int      @default(0)
  importPhotosFound Int       @default(0)
  importVideosFound Int       @default(0)
  importError    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lastImportedAt DateTime?
  coverAsset     ModelAsset?  @relation("ModelCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  assets         ModelAsset[]
}

model ModelAsset {
  id              String   @id @default(cuid())
  modelId         String
  fullPath        String   @unique
  relativePath    String
  folderPath      String
  fileName        String
  assetType       String
  extension       String
  thumbnailPath   String?
  sizeBytes       BigInt?
  durationSeconds Int?
  missing         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastSeenAt      DateTime
  model           Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  coverForModels  Model[]  @relation("ModelCoverAsset")

  @@index([modelId])
  @@index([modelId, assetType])
  @@index([folderPath])
  @@index([updatedAt])
}
